# ============================================
# DOCKER COMPOSE ENVIRONMENT VARIABLES
# Copy this to .env and customize values
# ============================================

# Database Configuration
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=saas_db
DB_PORT=5432

# Redis Configuration
REDIS_PORT=6379

# Backend Configuration
BACKEND_PORT=5000
NODE_ENV=development
PORT=5000

# Client URL (for CORS)
CLIENT_URL=http://localhost:3000

# JWT Secrets (CRITICAL: Change these in production!)
ACCESS_TOKEN_SECRET=change_this_secret_in_production_minimum_32_chars
REFRESH_TOKEN_SECRET=change_this_secret_in_production_minimum_32_chars

# Frontend Configuration
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:5000/api
